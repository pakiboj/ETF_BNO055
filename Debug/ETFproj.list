08000f3c <MQTT_Init>:
void AT_Receive(void) {
    memset(uart3_buf, 0, sizeof(uart3_buf));
    HAL_UART_Receive(&huart3, (uint8_t*)uart3_buf, sizeof(uart3_buf)-1, 1000);
}

